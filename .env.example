# Copy to .env and adjust. Never commit .env.

MYSQL_HOST=localhost
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=flipkart_clone

# Aliases (Railway/Render): DB_HOST, DB_USER, DB_PASSWORD, DB_NAME

JWT_SECRET=change-this-to-a-long-random-string

PORT=3001

# Production (npm run build && npm start): set NODE_ENV=production in npm script.
# Subpath hosting: set before build, e.g. VITE_BASE=/shop/
# VITE_BASE=/

# Optional bind address (default 0.0.0.0 in production)
# HOST=0.0.0.0

# Split deploy: frontend build must set VITE_API_URL to your API origin (no trailing slash).
# VITE_API_URL=https://your-api.onrender.com

# Split deploy: backend allowlist for browser origins (comma-separated). Example:
# CORS_ORIGIN=https://your-app.vercel.app

# Order emails — either SMTP_* or common aliases (Gmail: host inferred if omitted):
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@gmail.com
# SMTP_PASS=app-password
# MAIL_FROM=you@gmail.com
# EMAIL_USER=you@gmail.com
# EMAIL_PASS=app-password
# SMTP_TLS_REJECT_UNAUTHORIZED=true
